    ML_MODEL ||--o{ PREDICTION : "generates decision"

    APPLICANT {
        int ID PK
        string CODE_GENDER
        string FLAG_OWN_CAR
        string FLAG_OWN_REALTY
        int CNT_CHILDREN
        float AMT_INCOME_TOTAL
        string NAME_INCOME_TYPE
        string NAME_EDUCATION_TYPE
        string NAME_FAMILY_STATUS
        string NAME_HOUSING_TYPE
        int DAYS_BIRTH
        int DAYS_EMPLOYED
        int FLAG_MOBIL
        int FLAG_WORK_PHONE
        int FLAG_PHONE
        int FLAG_EMAIL
        string OCCUPATION_TYPE
        float CNT_FAM_MEMBERS
    }

    CREDIT_RECORD {
        int ID FK
        int MONTHS_BALANCE
        string STATUS
    }

    PREDICTION {
        int PREDICTION_ID PK
        int APPLICANT_ID FK
        float CONFIDENCE_SCORE
        string DECISION_STATUS
        datetime EVALUATION_TIME
    }

    ML_MODEL {
        string MODEL_NAME PK
        float ACCURACY
        float AUC_SCORE
        string MODEL_FILE_PATH
    }

    WEB_APPLICATION {
        string SERVER_HOST
        int SERVER_PORT
        string ROUTES_LIST
    }
